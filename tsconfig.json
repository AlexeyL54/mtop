{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "./web",
    "rootDir": "./web",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "removeComments": false,
    "sourceMap": true
  },
  "include": ["web/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
